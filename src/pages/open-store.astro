---
import Layout from "../layouts/Layout.astro";
import Icon from "../components/ui/Icon.astro";
---

<Layout title="Buka Toko — Lapakku" description="Daftar dan buka toko online gratis di Lapakku dalam hitungan menit.">
  <div class="min-h-screen bg-gradient-to-b from-[#F4FAFF] to-white">
    <!-- Simple Nav -->
    <div class="wrap flex items-center justify-between py-4">
      <a href="/" class="flex items-center gap-2 font-heading font-extrabold text-xl -tracking-[.03em]">
        <span class="relative flex-none w-[34px] h-[34px] rounded-[11px] grad-ocean shadow-glow grid place-items-center overflow-hidden">
          <span class="absolute inset-0 bg-gradient-to-b from-white/50 to-transparent"></span>
          <Icon name="bag" class="relative z-10 text-white" size={20} />
        </span>
        <b class="text-ocean-700">Lapakku</b>
      </a>
      <a href="/" class="text-sm font-semibold text-ink-soft hover:text-ocean-700 transition-colors">
        <span class="hidden sm:inline">Kembali ke</span> Beranda
      </a>
    </div>

    <!-- Form Section -->
    <div class="wrap py-6 pb-20 max-w-[620px]">
      <div id="form-container">
        <!-- Header -->
        <div class="text-center mb-9 reveal">
          <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-white/70 backdrop-blur-md border border-[var(--line-strong)] rounded-full text-sm font-semibold text-ocean-700 shadow-sm mb-5">
            <span class="grad-ocean text-white text-[.72rem] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full">Gratis</span>
            Tanpa kartu kredit
          </span>
          <h1 class="text-[clamp(1.8rem,3.5vw,2.6rem)] font-extrabold -tracking-[.035em] mb-3">
            Buka Toko Online-mu
          </h1>
          <p class="text-ink-soft text-[clamp(.95rem,1.2vw,1.08rem)] max-w-[28em] mx-auto">
            Isi data di bawah dan dapatkan toko online profesional dalam hitungan menit.
          </p>
        </div>

        <!-- Form Card -->
        <div class="bg-white/70 backdrop-blur-xl border border-[var(--line)] rounded-[var(--radius-lg)] shadow-lg p-8 max-md:p-5">
          <form id="register-form" novalidate>
            <!-- Store Name -->
            <div class="mb-5">
              <label for="store-name" class="block text-sm font-bold text-ink mb-1.5">Nama Toko <span class="text-red-500">*</span></label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint">
                  <Icon name="store" size={18} />
                </span>
                <input
                  id="store-name"
                  type="text"
                  placeholder="contoh: Toko Rani"
                  required
                  minlength="3"
                  maxlength="50"
                  class="w-full bg-white border border-[var(--line-strong)] rounded-[14px] pl-10 pr-4 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                />
              </div>
              <p class="text-xs text-ink-faint mt-1.5 ml-1" id="store-name-hint">Minimal 3 karakter</p>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="store-name-error">Nama toko harus diisi minimal 3 karakter</p>
            </div>

            <!-- Subdomain -->
            <div class="mb-5">
              <label for="subdomain" class="block text-sm font-bold text-ink mb-1.5">Subdomain <span class="text-red-500">*</span></label>
              <div class="flex items-stretch">
                <div class="relative flex-1">
                  <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint">
                    <Icon name="globe" size={18} />
                  </span>
                  <input
                    id="subdomain"
                    type="text"
                    placeholder="namatoko"
                    required
                    minlength="3"
                    maxlength="30"
                    pattern="[a-z0-9-]+"
                    class="w-full bg-white border border-[var(--line-strong)] rounded-l-[14px] pl-10 pr-3 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                  />
                </div>
                <span class="inline-flex items-center px-3.5 bg-[var(--color-bg-soft-2)] border border-l-0 border-[var(--line-strong)] text-ink-faint text-sm font-medium rounded-r-[14px] whitespace-nowrap">.lapakku.id</span>
              </div>
              <p class="text-xs text-ink-faint mt-1.5 ml-1" id="subdomain-hint">Hanya huruf kecil, angka, dan tanda hubung</p>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="subdomain-error">Hanya huruf kecil, angka, dan tanda hubung (min 3 karakter)</p>
              <p class="text-xs text-teal font-semibold mt-1.5 ml-1 hidden" id="subdomain-available">
                <Icon name="check" size={14} class="inline align-text-top" /> Tersedia!
              </p>
            </div>

            <!-- Email -->
            <div class="mb-5">
              <label for="email" class="block text-sm font-bold text-ink mb-1.5">Email <span class="text-red-500">*</span></label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint">
                  <Icon name="mail" size={18} />
                </span>
                <input
                  id="email"
                  type="email"
                  placeholder="kamu@email.com"
                  required
                  class="w-full bg-white border border-[var(--line-strong)] rounded-[14px] pl-10 pr-4 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                />
              </div>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="email-error">Masukkan email yang valid</p>
            </div>

            <!-- WhatsApp -->
            <div class="mb-5">
              <label for="whatsapp" class="block text-sm font-bold text-ink mb-1.5">Nomor WhatsApp <span class="text-ink-faint text-xs font-normal">(opsional)</span></label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint">
                  <Icon name="phone" size={18} />
                </span>
                <input
                  id="whatsapp"
                  type="tel"
                  placeholder="0812-3456-7890"
                  class="w-full bg-white border border-[var(--line-strong)] rounded-[14px] pl-10 pr-4 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                />
              </div>
              <p class="text-xs text-ink-faint mt-1.5 ml-1">Untuk notifikasi order dan update toko</p>
            </div>

            <!-- Password -->
            <div class="mb-5">
              <label for="password" class="block text-sm font-bold text-ink mb-1.5">Password <span class="text-red-500">*</span></label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint z-10">
                  <Icon name="shield" size={18} />
                </span>
                <input
                  id="password"
                  type="password"
                  placeholder="Minimal 8 karakter"
                  required
                  minlength="8"
                  class="w-full bg-white border border-[var(--line-strong)] rounded-[14px] pl-10 pr-10 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                />
                <button type="button" id="toggle-password" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-ink-faint hover:text-ink cursor-pointer" tabindex="-1">
                  <Icon name="eye" id="eye-icon" size={18} />
                </button>
              </div>
              <!-- Strength -->
              <div class="mt-2 flex items-center gap-2" id="strength-bar">
                <div class="flex-1 h-1.5 rounded-full bg-[var(--color-bg-soft-2)] overflow-hidden">
                  <div id="strength-fill" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
                </div>
                <span id="strength-label" class="text-xs text-ink-faint font-medium min-w-[60px] text-right"></span>
              </div>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="password-error">Password minimal 8 karakter</p>
            </div>

            <!-- Confirm Password -->
            <div class="mb-6">
              <label for="confirm-password" class="block text-sm font-bold text-ink mb-1.5">Konfirmasi Password <span class="text-red-500">*</span></label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-ink-faint z-10">
                  <Icon name="shield" size={18} />
                </span>
                <input
                  id="confirm-password"
                  type="password"
                  placeholder="Ulangi password"
                  required
                  class="w-full bg-white border border-[var(--line-strong)] rounded-[14px] pl-10 pr-4 py-3 text-sm text-ink placeholder:text-ink-faint/60 outline-none transition-all duration-200 focus:border-ocean-500 focus:ring-2 focus:ring-ocean-500/20"
                />
              </div>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="confirm-password-error">Password tidak cocok</p>
            </div>

            <!-- Terms -->
            <div class="mb-7">
              <label class="flex items-start gap-3 cursor-pointer">
                <input
                  id="terms"
                  type="checkbox"
                  required
                  class="mt-0.5 w-4 h-4 rounded border-[var(--line-strong)] text-ocean-500 focus:ring-ocean-500/30 focus:ring-offset-0 cursor-pointer"
                />
                <span class="text-sm text-ink-soft leading-relaxed">
                  Saya setuju dengan
                  <a href="/syarat-ketentuan" class="text-ocean-500 hover:text-ocean-700 font-semibold underline underline-offset-2">Syarat &amp; Ketentuan</a>
                  dan
                  <a href="/kebijakan-privasi" class="text-ocean-500 hover:text-ocean-700 font-semibold underline underline-offset-2">Kebijakan Privasi</a>
                  Lapakku
                </span>
              </label>
              <p class="text-xs text-red-500 mt-1.5 ml-1 hidden" id="terms-error">Anda harus menyetujui syarat & ketentuan</p>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              id="submit-btn"
              class="w-full inline-flex items-center justify-center gap-2 rounded-full font-semibold text-white px-[1.8em] py-[1.05em] text-[1.02rem] grad-ocean shadow-glow shadow-[inset_0_1px_0_rgba(255,255,255,.4)] hover:-translate-y-0.5 hover:shadow-[0_28px_60px_-12px_rgba(17,131,214,.7),inset_0_1px_0_rgba(255,255,255,.5)] transition-all duration-300 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
            >
              <span id="submit-text">Buka Toko Sekarang</span>
              <span id="submit-spinner" class="hidden">
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                </svg>
              </span>
            </button>

            <p class="text-xs text-ink-faint text-center mt-4">Dengan mendaftar, kamu setuju data kamu diproses sesuai <a href="/kebijakan-privasi" class="text-ocean-500 hover:text-ocean-700 underline underline-offset-2">Kebijakan Privasi</a> kami.</p>
          </form>
        </div>

        <!-- Trust Badges -->
        <p class="text-center text-xs text-ink-faint mt-6 flex items-center justify-center gap-4 flex-wrap">
          <span class="inline-flex items-center gap-1"><Icon name="shield" size={14} /> Data terenkripsi</span>
          <span class="inline-flex items-center gap-1"><Icon name="clock" size={14} /> Setup &lt; 5 menit</span>
          <span class="inline-flex items-center gap-1"><Icon name="check-circle" size={14} /> Gratis selamanya</span>
        </p>
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  .select-custom {
    appearance: none;
    background-image: url("data:image/svg+xml,%3Csvg width='10' height='6' viewBox='0 0 10 6' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 1l4 4 4-4' stroke='%23456178' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: right 14px center;
    padding-right: 36px;
  }
</style>

<script>
  const form = document.getElementById("register-form");
  const storeName = document.getElementById("store-name");
  const subdomain = document.getElementById("subdomain");
  const email = document.getElementById("email");
  const whatsapp = document.getElementById("whatsapp");
  const password = document.getElementById("password");
  const confirmPassword = document.getElementById("confirm-password");
  const terms = document.getElementById("terms");

  const togglePassword = document.getElementById("toggle-password");
  const eyeIcon = document.getElementById("eye-icon");
  const strengthFill = document.getElementById("strength-fill");
  const strengthLabel = document.getElementById("strength-label");
  const submitBtn = document.getElementById("submit-btn");
  const submitText = document.getElementById("submit-text");
  const submitSpinner = document.getElementById("submit-spinner");

  // Toggle password visibility
  togglePassword?.addEventListener("click", () => {
    const hidden = password.type === "password";
    password.type = hidden ? "text" : "password";
    if (eyeIcon) {
      eyeIcon.setAttribute("name", hidden ? "eye-off" : "eye");
    }
  });

  // Password strength
  password?.addEventListener("input", () => {
    const val = password.value;
    const len = val.length;
    let score = 0;
    if (len >= 8) score += 25;
    if (/[a-z]/.test(val)) score += 15;
    if (/[A-Z]/.test(val)) score += 20;
    if (/\d/.test(val)) score += 20;
    if (/[^a-zA-Z0-9]/.test(val)) score += 20;

    strengthFill.style.width = Math.min(score, 100) + "%";
    if (score < 25) {
      strengthFill.className = "h-full rounded-full bg-red-400 transition-all duration-300";
      strengthLabel.textContent = "Terlalu pendek";
    } else if (score < 50) {
      strengthFill.className = "h-full rounded-full bg-orange-400 transition-all duration-300";
      strengthLabel.textContent = "Lemah";
    } else if (score < 75) {
      strengthFill.className = "h-full rounded-full bg-yellow-500 transition-all duration-300";
      strengthLabel.textContent = "Sedang";
    } else {
      strengthFill.className = "h-full rounded-full bg-teal transition-all duration-300";
      strengthLabel.textContent = "Kuat";
    }
  });

  // Subdomain validation and availability simulation
  let subdomainTimer;
  subdomain?.addEventListener("input", () => {
    clearTimeout(subdomainTimer);
    const val = subdomain.value.toLowerCase();
    subdomain.value = val;
    const available = document.getElementById("subdomain-available");
    const hint = document.getElementById("subdomain-hint");
    const err = document.getElementById("subdomain-error");
    available.classList.add("hidden");
    hint.classList.remove("hidden");
    err.classList.add("hidden");

    if (val.length >= 3 && /^[a-z0-9-]+$/.test(val)) {
      subdomainTimer = setTimeout(() => {
        available.classList.remove("hidden");
        hint.classList.add("hidden");
      }, 600);
    }
  });

  // Real-time match check for confirm password
  confirmPassword?.addEventListener("input", () => {
    document.getElementById("confirm-password-error").classList.add("hidden");
  });

  // Helper to show error
  function showError(id) {
    const el = document.getElementById(id);
    if (el) el.classList.remove("hidden");
  }

  function hideError(id) {
    const el = document.getElementById(id);
    if (el) el.classList.add("hidden");
  }

  // Form submission
  form?.addEventListener("submit", (e) => {
    e.preventDefault();

    // Reset errors
    document.querySelectorAll("[id$=-error]").forEach((el) => el.classList.add("hidden"));
    hideError("subdomain-available");

    let valid = true;

    // Store name
    if (!storeName.value || storeName.value.trim().length < 3) {
      showError("store-name-error");
      valid = false;
    }

    // Subdomain
    if (!subdomain.value || !/^[a-z0-9-]{3,}$/.test(subdomain.value)) {
      showError("subdomain-error");
      valid = false;
    }

    // Email
    if (!email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
      showError("email-error");
      valid = false;
    }

    // Password
    if (!password.value || password.value.length < 8) {
      showError("password-error");
      valid = false;
    }

    // Confirm password
    if (password.value !== confirmPassword.value) {
      showError("confirm-password-error");
      valid = false;
    }

    // Terms
    if (!terms.checked) {
      showError("terms-error");
      valid = false;
    }

    if (!valid) {
      const firstError = document.querySelector(".text-red-500:not(.hidden)");
      if (firstError) {
        const input = firstError.closest(".mb-5, .mb-6, .mb-7")?.querySelector("input, select");
        input?.scrollIntoView({ behavior: "smooth", block: "center" });
        input?.focus();
      }
      return;
    }

    // Simulate submission
    submitBtn.disabled = true;
    submitText.classList.add("hidden");
    submitSpinner.classList.remove("hidden");

    const emailVal = email.value;

    setTimeout(() => {
      window.location.href = "/open-store/success?email=" + encodeURIComponent(emailVal);
    }, 1800);
  });
</script>
