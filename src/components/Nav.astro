---
import Icon from "./ui/Icon.astro";

export interface Props {
    links?: Array<{ label: string; href: string }>;
}

const {
    links = [
        { label: "Fitur", href: "#fitur" },
        { label: "Marketplace", href: "#marketplace" },
        { label: "Template", href: "#template" },
        { label: "Harga", href: "#harga" },
        { label: "Cerita", href: "#cerita" },
    ],
} = Astro.props;
---

<header
    id="header"
    class="fixed top-0 inset-x-0 z-50 transition-all duration-500"
>
    <div class="wrap">
        <nav
            class="flex items-center justify-between rounded-full px-[1.3rem] max-md:px-3 py-[.7rem] max-md:py-[.55rem] mt-[18px] bg-white/60 backdrop-blur-xl saturate-140 border border-white/70 shadow-[0_10px_30px_-14px_rgba(8,70,124,.28)] transition-all duration-500"
        >
            <a
                href="#"
                class="flex items-center gap-2 font-heading font-extrabold text-[clamp(1.1rem,1.8vw,1.32rem)] -tracking-[.03em]"
            >
                <span
                    class="relative flex-none w-[34px] h-[34px] md:w-[38px] md:h-[38px] rounded-[11px] grad-ocean shadow-glow grid place-items-center overflow-hidden"
                >
                    <span
                        class="absolute inset-0 bg-gradient-to-b from-white/50 to-transparent"
                    ></span>
                    <Icon
                        name="bag"
                        class="relative z-10 text-white"
                        size={20}
                    />
                </span>
                <b class="text-ocean-700">Lapakku</b>
            </a>

            <div class="hidden md:flex items-center gap-1 max-lg:gap-0">
                {
                    links.map((l) => (
                        <a
                            href={l.href}
                            class="px-3.5 max-lg:px-2.5 py-2 rounded-full font-medium text-sm max-lg:text-xs text-ink-soft hover:text-ocean-700 hover:bg-ocean-500/10 transition-all"
                        >
                            {l.label}
                        </a>
                    ))
                }
            </div>

            <div class="flex items-center gap-1 md:gap-2">
                <a
                    href="#"
                    class="hidden max-lg:hidden lg:inline font-semibold text-sm px-3 py-2.5 text-ink"
                    >Masuk</a
                >
                <a
                    href="#harga"
                    class="inline-flex items-center gap-2 rounded-full font-semibold whitespace-nowrap text-white px-[1.4em] py-[.85em] text-[clamp(.75rem,.95vw,.96rem)] grad-ocean shadow-glow shadow-[inset_0_1px_0_rgba(255,255,255,.4)] hover:-translate-y-0.5 hover:shadow-[0_28px_60px_-12px_rgba(17,131,214,.7),inset_0_1px_0_rgba(255,255,255,.5)] transition-all duration-300"
                >
                    <span class="hidden max-lg:hidden lg:inline"
                        >Mulai Gratis</span
                    >
                    <Icon name="arrow-right" size={18} />
                </a>
                <button
                    id="burger"
                    class="grid md:hidden w-10 h-10 rounded-xl bg-white/70 border line place-items-center cursor-pointer"
                    aria-label="Menu"
                >
                    <span id="burger-icon"
                        class="block w-[16px] h-[2px] bg-ink rounded transition-all duration-300 relative before:absolute before:left-0 before:w-[16px] before:h-[2px] before:bg-ink before:rounded before:-top-[5px] before:transition-all before:duration-300 after:absolute after:left-0 after:w-[16px] after:h-[2px] after:bg-ink after:rounded after:top-[5px] after:transition-all after:duration-300"
                    ></span>
                </button>
            </div>
        </nav>
    </div>
</header>

<!-- Mobile menu overlay (sibling of header, not child) -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-40 md:hidden opacity-0 pointer-events-none transition-opacity duration-400"
>
    <div id="menu-backdrop" class="absolute inset-0 bg-black/30 backdrop-blur-sm will-change-[backdrop-filter] translate-z-0"></div>
    <div
        id="menu-panel"
        class="absolute top-[76px] left-3 right-3 bg-white rounded-2xl border line shadow-xl pt-3 pb-4 px-3 -translate-y-4 opacity-0 transition-all duration-300 ease-[cubic-bezier(.22,.61,.36,1)]"
        style="transition-property: transform, opacity;"
    >
        <nav class="flex flex-col gap-0.5">
            {
                links.map((l) => (
                    <a
                        href={l.href}
                        class="text-base font-semibold text-ink-soft hover:text-ocean-700 hover:bg-ocean-500/5 px-4 py-3 rounded-xl transition-all"
                    >
                        {l.label}
                    </a>
                ))
            }
            <hr class="my-1.5 mx-2 border-[var(--line)]" />
            <a
                href="#"
                class="text-base font-semibold text-ink-soft hover:text-ocean-700 hover:bg-ocean-500/5 px-4 py-3 rounded-xl transition-all"
                >Masuk</a
            >
            <a
                href="#harga"
                class="mt-2 mx-2 text-center rounded-full font-semibold text-white px-6 py-3.5 text-base grad-ocean shadow-glow shadow-[inset_0_1px_0_rgba(255,255,255,.4)] hover:-translate-y-0.5 hover:shadow-[0_28px_60px_-12px_rgba(17,131,214,.7),inset_0_1px_0_rgba(255,255,255,.5)] transition-all duration-300"
                >Mulai Gratis</a
            >
        </nav>
    </div>
</div>

<style>
    header.scrolled nav {
        margin-top: 0.6rem;
        background: rgba(255, 255, 255, 0.82);
        box-shadow: 0 14px 34px -16px rgba(8, 70, 124, 0.4);
    }
</style>

<script>
    const header = document.getElementById("header");
    const onScroll = () =>
        header.classList.toggle("scrolled", window.scrollY > 20);
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();

    const burger = document.getElementById("burger");
    const menu = document.getElementById("mobile-menu");
    const panel = document.getElementById("menu-panel");
    const backdrop = document.getElementById("menu-backdrop");
    const burgerIcon = document.getElementById("burger-icon");
    const body = document.body;

    function toggleMenu(open) {
        menu.classList.toggle("pointer-events-none", !open);
        menu.classList.toggle("pointer-events-auto", open);
        menu.classList.toggle("opacity-0", !open);
        menu.classList.toggle("opacity-100", open);
        panel.classList.toggle("-translate-y-4", !open);
        panel.classList.toggle("translate-y-0", open);
        panel.classList.toggle("opacity-0", !open);
        panel.classList.toggle("opacity-100", open);
        body.classList.toggle("overflow-hidden", open);
        burgerIcon.classList.toggle("rotate-45", open);
        burgerIcon.classList.toggle("before:opacity-0", open);
        burgerIcon.classList.toggle("after:-translate-y-[5px]", open);
        burgerIcon.classList.toggle("after:rotate-[-45deg]", open);
        burgerIcon.classList.toggle("before:-translate-y-[5px]", open);
        burgerIcon.classList.toggle("bg-transparent", open);
    }

    burger?.addEventListener("click", () => {
        toggleMenu(menu.classList.contains("opacity-0"));
    });

    backdrop?.addEventListener("click", () => toggleMenu(false));

    panel.querySelectorAll("a").forEach((a) => {
        a.addEventListener("click", () => toggleMenu(false));
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") toggleMenu(false);
    });
</script>
