---
import Icon from "./ui/Icon.astro";
---

<footer
    class="py-20 max-md:py-14 pb-9 max-md:pb-6 bg-[var(--color-bg-soft)] border-t line"
>
    <div class="wrap">
        <div
            class="grid grid-cols-[1.6fr_1fr_1fr_1fr_1fr] gap-10 mb-[clamp(2rem,3.8vw,3rem)] max-lg:grid-cols-2 max-md:grid-cols-2 max-sm:grid-cols-1"
        >
            <!-- Brand -->
            <div
                class="max-lg:col-span-2 max-sm:col-span-1 max-md:text-center max-sm:text-left"
            >
                <a
                    href="#"
                    class="inline-flex items-center gap-2 font-heading font-extrabold text-[clamp(1.1rem,1.8vw,1.32rem)] -tracking-[.03em] mb-4 max-md:justify-center max-sm:justify-start"
                >
                    <span
                        class="relative flex-none w-[38px] h-[38px] max-md:w-[34px] max-md:h-[34px] rounded-[11px] grad-ocean shadow-glow grid place-items-center overflow-hidden"
                    >
                        <span
                            class="absolute inset-0 bg-gradient-to-b from-white/50 to-transparent"
                        ></span>
                        <Icon
                            name="bag"
                            class="relative z-10 text-white"
                            size={20}
                        />
                    </span>
                    <b class="text-ocean-700">Lapakku</b>
                </a>
                <p
                    class="text-ink-soft text-sm max-w-[24em] mb-4 max-md:mx-auto"
                >
                    Platform pembuat toko online modern untuk UMKM dan brand
                    Indonesia. Jualan jadi mudah, profesional, dan punya brand
                    sendiri.
                </p>
                <div
                    class="flex gap-2 max-md:justify-center max-sm:justify-start"
                >
                    {
                        [
                            { label: "Instagram", icon: "instagram" },
                            { label: "Twitter", icon: "twitter" },
                            { label: "TikTok", icon: "tiktok" },
                            { label: "YouTube", icon: "youtube" },
                        ].map((s) => (
                            <a
                                href="#"
                                aria-label={s.label}
                                class="w-[38px] h-[38px] rounded-[11px] bg-white border line grid place-items-center text-ink-soft hover:text-white hover:grad-ocean hover:border-transparent hover:-translate-y-0.5 transition-all duration-300"
                            >
                                <Icon name={s.icon} size={18} />
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- Columns -->
            {
                [
                    {
                        title: "Produk",
                        links: [
                            "Page Builder",
                            "Pembayaran",
                            "Pengiriman",
                            "Analitik",
                            "Template",
                        ],
                    },
                    {
                        title: "Solusi",
                        links: [
                            "Fashion",
                            "Kuliner",
                            "Elektronik",
                            "Jasa & Digital",
                            "Enterprise",
                        ],
                    },
                    {
                        title: "Sumber Daya",
                        links: [
                            "Pusat Bantuan",
                            "Blog Penjual",
                            "Akademi Lapakku",
                            "Status",
                            "API Docs",
                        ],
                    },
                    {
                        title: "Perusahaan",
                        links: [
                            "Tentang Kami",
                            "Karier",
                            "Mitra",
                            "Kontak",
                            "Privasi",
                        ],
                    },
                ].map((col) => (
                    <div>
                        <h5 class="text-[.78rem] uppercase tracking-widest text-ink-faint mb-4 font-body font-bold">
                            {col.title}
                        </h5>
                        {col.links.map((l) => (
                            <a
                                href="#"
                                class="block text-ink-soft text-sm mb-3 last:mb-0 hover:text-ocean-700 hover:translate-x-0.5 transition-all"
                            >
                                {l}
                            </a>
                        ))}
                    </div>
                ))
            }
        </div>

        <div
            class="flex items-center justify-between pt-6 border-t line text-sm text-ink-faint flex-wrap gap-3.5 max-md:flex-col max-md:text-center"
        >
            <span>© 2026 Lapakku. Seluruh hak cipta dilindungi.</span>
            <span class="flex items-center gap-1.5"
                >Dibuat dengan <span class="text-[#FF6B6B]">♥</span> di Jakarta, Indonesia</span
            >
        </div>
    </div>
</footer>
