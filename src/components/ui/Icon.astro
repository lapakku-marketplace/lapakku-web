---
export interface Props {
  name:
    | "cart"
    | "arrow-right"
    | "check"
    | "star"
    | "search"
    | "heart"
    | "star-filled"
    | "play"
    | "bag"
    | "bolt"
    | "chart"
    | "chat"
    | "box"
    | "truck"
    | "credit-card"
    | "tag"
    | "shield"
    | "layers"
    | "instagram"
    | "twitter"
    | "tiktok"
    | "youtube"
    | "store"
    | "package";
  class?: string;
  size?: number;
}

const { name, class: className = "", size = 24 } = Astro.props;
const svgSize = size;
---

<svg width={svgSize} height={svgSize} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
  {
    name === "cart" && <><path d="M6 6h15l-1.5 9h-12L6 6zM6 6L5 3H2M8 20a1 1 0 100-2 1 1 0 000 2zM18 20a1 1 0 100-2 1 1 0 000 2z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "arrow-right" && <><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "check" && <><path d="M5 12l4 4L19 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "star" && <><path d="M12 2l3 6.5 7 .6-5.3 4.6L18.2 21 12 17.3 5.8 21l1.5-7.3L2 9.1l7-.6z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/></>
  }
  {
    name === "search" && <><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/><path d="M21 21l-4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></>
  }
  {
    name === "heart" && <><path d="M20 8.5c0-2.5-2-4.5-4.5-4.5-1.7 0-3 .9-3.5 2-.5-1.1-1.8-2-3.5-2C6 4 4 6 4 8.5c0 4 8 9.5 8 9.5s8-5.5 8-9.5z" stroke="currentColor" stroke-width="1.8"/></>
  }
  {
    name === "play" && <><path d="M8 5v14l11-7z" fill="currentColor"/></>
  }
  {
    name === "bag" && <><path d="M3 9l2-4h14l2 4M3 9v9a1 1 0 001 1h16a1 1 0 001-1V9M3 9h18M9 13h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "bolt" && <><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></>
  }
  {
    name === "chart" && <><path d="M3 3v18h18M7 14l3-4 3 3 5-7" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "chat" && <><path d="M21 11.5a8.4 8.4 0 01-9 8.5 8.6 8.6 0 01-4-1L3 21l1.5-5a8.5 8.5 0 1116.5-3.5z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></>
  }
  {
    name === "box" && <><path d="M20 7l-8-4-8 4 8 4 8-4zM4 7v10l8 4 8-4V7M12 11v10" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "truck" && <><path d="M1 3h13v13H1zM14 8h4l3 3v5h-7M5.5 19a2 2 0 100-4 2 2 0 000 4zM18.5 19a2 2 0 100-4 2 2 0 000 4z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "credit-card" && <><rect x="2" y="5" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.8"/><path d="M2 10h20M6 15h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></>
  }
  {
    name === "tag" && <><path d="M20.6 13.4L13.4 20.6a2 2 0 01-2.8 0l-7-7A2 2 0 013 12V5a2 2 0 012-2h7a2 2 0 011.4.6l7.2 7.2a2 2 0 010 2.6z" stroke="currentColor" stroke-width="1.8"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/></>
  }
  {
    name === "shield" && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></>
  }
  {
    name === "layers" && <><path d="M4 4h16v12H5.2L4 18V4z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/><path d="M8 9h8M8 12h5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></>
  }
  {
    name === "instagram" && <><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></>
  }
  {
    name === "twitter" && <><path d="M22 5.8c-.7.3-1.5.6-2.3.7a4 4 0 001.8-2.2c-.8.5-1.7.8-2.6 1a4 4 0 00-6.8 3.6A11.3 11.3 0 013 4.8a4 4 0 001.2 5.3c-.6 0-1.2-.2-1.8-.5a4 4 0 003.2 4 4 4 0 01-1.8.1 4 4 0 003.7 2.8A8 8 0 012 18.3a11.3 11.3 0 006.1 1.8c7.3 0 11.4-6.1 11.4-11.4v-.5c.8-.6 1.5-1.3 2-2.1z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/></>
  }
  {
    name === "tiktok" && <><path d="M16 3c.3 2.3 1.8 4 4 4.3V11c-1.5 0-3-.5-4-1.3V16a5.5 5.5 0 11-5.5-5.5c.3 0 .6 0 .9.1V14a2.5 2.5 0 101.8 2.4V3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></>
  }
  {
    name === "youtube" && <><rect x="2" y="5" width="20" height="14" rx="4" stroke="currentColor" stroke-width="1.8"/><path d="M10 9l5 3-5 3V9z" fill="currentColor"/></>
  }
  {
    name === "store" && <><path d="M12 2l2.4 7.4H22l-6 4.5 2.3 7.1-6.3-4.6L5.7 21 8 13.9 2 9.4h7.6z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></>
  }
  {
    name === "package" && <><path d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></>
  }
</svg>

<style>
  svg {
    flex: none;
  }
</style>
